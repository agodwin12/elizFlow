# ── ElizFlow API environment ───────────────────────────────────────
# Copy to .env and fill in. Never commit the real .env.

# Database (use the EXISTING VPS Postgres; via host.docker.internal in Docker)
DATABASE_URL="postgresql://USER:PASSWORD@host.docker.internal:5432/elizflow?schema=public"

# Server
PORT=11000
NODE_ENV=production

# Auth secrets — set to long random strings
JWT_SECRET="change-me-to-a-long-random-string"
JWT_REFRESH_SECRET="change-me-to-another-long-random-string"

# Password reset: keep "true" until the mobile app sends OTP codes, then
# set to "false" to make SMS OTP verification mandatory.
ALLOW_LEGACY_RESET="true"
OTP_TTL_MIN=10

# ── Techsoft SMS (used for password-reset OTP) ─────────────────────
TECHSOFT_API_TOKEN=""
TECHSOFT_SENDER_ID="ELIZFLOW"
# TECHSOFT_SMS_URL="https://app.techsoft-sms.com/api/http/sms/send/"

# ── Firebase (push notifications) ──────────────────────────────────
# Provide firebase-service-account.json in the app directory (bind-mounted).

# ── Cloudflare R2 (image uploads) ──────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""

# ── Gemini (demand forecast) ───────────────────────────────────────
GEMINI_API_KEY=""

# Scaling / tuning (optional)
DB_POOL_MAX=15
DB_POOL_IDLE_MS=30000
DB_POOL_CONN_TIMEOUT_MS=10000
AUTH_RATE_MAX=40
AUTH_RATE_WINDOW_MIN=15
TRIAL_DAYS=14
