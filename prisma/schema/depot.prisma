enum BusinessType {
  DEPOT // beer depot – sells mostly full crates
  BAR // retail bar – sells mostly single bottles/units
  RETAIL // general retail – sells units
  HYBRID // sells both packages and units
}

enum SubscriptionStatus {
  TRIAL // in free trial
  ACTIVE // paid & current
  PAST_DUE // expired but within grace period
  BLOCKED // manually blocked by super admin (e.g. non-payment)
  EXPIRED // subscription lapsed
}

model Depot {
  id        String   @id @default(cuid())
  name      String
  address   String?
  phone     String?
  city      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  logoUrl   String?

  // ── Business configuration ────────────────────────────────────
  businessType BusinessType @default(DEPOT)
  currency     String       @default("FCFA")

  // Per-depot receipt sequence (incremented atomically per sale).
  lastReceiptNumber Int @default(0)

  // ── Subscription / billing ────────────────────────────────────
  subscriptionStatus SubscriptionStatus @default(TRIAL)
  subscriptionPlan   String? // e.g. BASIC / PRO – free-form
  trialEndsAt        DateTime?
  subscriptionEndsAt DateTime?
  gracePeriodDays    Int                @default(3)
  blockedReason      String?
  blockedAt          DateTime?

  users          User[]
  products       Product[]
  customers      Customer[]
  sales          Sale[]
  payments       Payment[]
  stockMovements StockMovement[]
  tournees       Tournee[]
  deliveryStops  DeliveryStop[]

  subscriptionPayments SubscriptionPayment[]
  registerShifts       RegisterShift[]
  expenses             Expense[]
  saleReturns          SaleReturn[]
  suppliers            Supplier[]
  auditLogs            AuditLog[]
  stockCounts          StockCount[]
}
